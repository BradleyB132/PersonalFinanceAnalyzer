# Local development environment variables
# Copy this file to .env for local development

# Database connection for local Docker PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/personalfinanceanalyzer

# Optional: Sentry DSN for error monitoring (leave empty for local development)
SENTRY_DSN=

# Optional: E2E test base URL (defaults to localhost:8501)
E2E_BASE_URL=http://localhost:8501